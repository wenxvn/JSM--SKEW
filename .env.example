# Clerk 开发实例的浏览器可公开键
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk 开发实例的服务端密钥，绝不能添加 NEXT_PUBLIC_ 前缀
CLERK_SECRET_KEY=

# Supabase 开发项目地址与浏览器可公开键
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 仅为未来受控的服务端后台任务预留；当前代码不会读取它
SUPABASE_SECRET_KEY=

# Oxylabs Web Scraper API 的服务端 Basic Auth 凭证
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# AI SDK 使用的服务端 Provider 与模型标识
AI_PROVIDER=
AI_BASE_URL=
AI_MODEL=
DASHSCOPE_API_KEY=

# OpenAI 项目 API Key，绝不能添加 NEXT_PUBLIC_ 前缀
OPENAI_API_KEY=

# PostHog 开发项目的浏览器公开令牌与所属区域采集端点
# 只在本机 .env.local 填写，绝不能提交真实值。
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
